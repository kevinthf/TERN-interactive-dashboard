leaflet(.) %>%
addTiles() %>%
addCircles(
lng = ~longitude_Degree,
lat = ~latitude_Degree,
radius = 2,
color = ~pal(abundance),
fillOpacity = 0.5
)%>%
addLegend(
"bottomright",
pal = pal,
values = ~abundance,
title = "Genus Abundance",
opacity = 1
)
}
